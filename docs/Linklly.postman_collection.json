{
  "info": {
    "name": "Linklly Backend API",
    "description": "Postman collection for the Linklly Express backend. Start the server with `npm run dev`, then run requests against `{{base_url}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"suzanne@example.com\",\n  \"username\": \"suzanne\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            },
            "description": "Create a new user and an empty profile. Password must be at least 8 characters."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"suzanne\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Log in and save the JWT to the collection variable `token`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/profile/{{username}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "profile",
                "{{username}}"
              ]
            },
            "description": "Fetch a public profile by username. This route does not require authentication."
          },
          "response": []
        },
        {
          "name": "Edit Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suzanne\",\n  \"bio\": \"Building Linklly\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "profile"
              ]
            },
            "description": "Update the authenticated user's profile."
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/reset",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reset"
              ]
            },
            "description": "Change the authenticated user's password."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delete",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "delete"
              ]
            },
            "description": "Delete the authenticated user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Links",
      "item": [
        {
          "name": "Create Link",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"GitHub\",\n  \"url\": \"https://github.com/swzxnne\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/links",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links"
              ]
            },
            "description": "Create a link for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Get My Links",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/links",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links"
              ]
            },
            "description": "Fetch the authenticated user's links, ordered by click count descending."
          },
          "response": []
        },
        {
          "name": "Update Link",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated GitHub\",\n  \"url\": \"https://github.com/swzxnne/Linklly\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/links/{{link_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links",
                "{{link_id}}"
              ]
            },
            "description": "Update a link owned by the authenticated user."
          },
          "response": []
        },
        {
          "name": "Delete Link",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/links/{{link_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links",
                "{{link_id}}"
              ]
            },
            "description": "Delete a link owned by the authenticated user."
          },
          "response": []
        },
        {
          "name": "Track Link Click",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/links/{{link_id}}/click",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "links",
                "{{link_id}}",
                "click"
              ]
            },
            "description": "Track a click for a link. This route is public."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "suzanne",
      "type": "string"
    },
    {
      "key": "link_id",
      "value": "1",
      "type": "string"
    }
  ]
}
